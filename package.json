{
  "name": "eupkgs-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Type-checking scaffold for TypeScript files in eupkgs (pi-mono extensions etc.). Not part of any Nix output.",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "biome check pkgs/by-name/ag/agent-statusline-pi/extension.ts",
    "format": "biome format --write pkgs/by-name/ag/agent-statusline-pi/extension.ts",
    "format:check": "biome format pkgs/by-name/ag/agent-statusline-pi/extension.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@mariozechner/pi-tui": "^0.70.2",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "typescript": "^6.0.3"
  }
}
