Subject: [PATCH 3/3] Add Made in EU composer badge


diff --git a/apps/web/src/components/MadeInEuBadge.test.tsx b/apps/web/src/components/MadeInEuBadge.test.tsx
new file mode 100644
index 0000000..05b9dd3
--- /dev/null
+++ b/apps/web/src/components/MadeInEuBadge.test.tsx
@@ -0,0 +1,19 @@
+import { renderToStaticMarkup } from "react-dom/server";
+import { describe, expect, it } from "vitest";
+
+import { MadeInEuBadge } from "./MadeInEuBadge";
+
+describe("MadeInEuBadge", () => {
+  it("renders accessible Made in EU text with an EU flag icon", () => {
+    const markup = renderToStaticMarkup(<MadeInEuBadge />);
+
+    expect(markup).toContain('aria-label="Made in EU"');
+    expect(markup).toContain('title="Made in EU"');
+    expect(markup).toContain(">Made in EU<");
+    expect(markup).toContain('viewBox="0 0 18 12"');
+    expect(markup).toContain('stroke="currentColor"');
+    expect(markup).toContain('fill="currentColor"');
+    expect(markup).not.toContain("#003399");
+    expect(markup).not.toContain("#FFCC00");
+  });
+});
diff --git a/apps/web/src/components/MadeInEuBadge.tsx b/apps/web/src/components/MadeInEuBadge.tsx
new file mode 100644
index 0000000..7ca256b
--- /dev/null
+++ b/apps/web/src/components/MadeInEuBadge.tsx
@@ -0,0 +1,58 @@
+import { Button } from "./ui/button";
+
+function EuFlagIcon() {
+  const starMarks = Array.from({ length: 12 }, (_, index) => {
+    const angle = (index / 12) * Math.PI * 2 - Math.PI / 2;
+    return {
+      x: 9 + Math.cos(angle) * 3,
+      y: 6 + Math.sin(angle) * 3,
+    };
+  });
+
+  return (
+    <svg
+      aria-hidden="true"
+      className="h-3.5 w-[21px] shrink-0 rounded-[2px]"
+      viewBox="0 0 18 12"
+      fill="none"
+    >
+      <rect
+        x="0.75"
+        y="0.75"
+        width="16.5"
+        height="10.5"
+        rx="1.75"
+        fill="currentColor"
+        opacity="0.1"
+      />
+      <rect
+        x="0.75"
+        y="0.75"
+        width="16.5"
+        height="10.5"
+        rx="1.75"
+        stroke="currentColor"
+        strokeWidth="1.5"
+      />
+      {starMarks.map((star) => (
+        <circle key={`${star.x}:${star.y}`} cx={star.x} cy={star.y} r="0.42" fill="currentColor" />
+      ))}
+    </svg>
+  );
+}
+
+export function MadeInEuBadge() {
+  return (
+    <Button
+      variant="ghost"
+      size="sm"
+      type="button"
+      className="hidden shrink-0 cursor-default whitespace-nowrap px-2 text-muted-foreground/70 hover:text-foreground/80 sm:inline-flex sm:px-3 [&_svg]:mx-0"
+      aria-label="Made in EU"
+      title="Made in EU"
+    >
+      <EuFlagIcon />
+      <span>Made in EU</span>
+    </Button>
+  );
+}
