From d8b31254189f149b84c45f63e9141d6261e92937 Mon Sep 17 00:00:00 2001
From: FlameFlag <git@ps1.sh>
Date: Mon, 1 Jun 2026 15:06:50 +0300
Subject: [PATCH 2/3] Shift empty placeholder off cursor cell

---
 codex-rs/tui/src/bottom_pane/chat_composer.rs | 25 +++++++++++++++++--
 1 file changed, 23 insertions(+), 2 deletions(-)

diff --git a/codex-rs/tui/src/bottom_pane/chat_composer.rs b/codex-rs/tui/src/bottom_pane/chat_composer.rs
index e62cab9..ec5aaf7 100644
--- a/codex-rs/tui/src/bottom_pane/chat_composer.rs
+++ b/codex-rs/tui/src/bottom_pane/chat_composer.rs
@@ -4322,9 +4322,30 @@ impl ChatComposer {
                     .to_string()
             };
             if !textarea_rect.is_empty() {
+                let placeholder_x = if self.draft.input_enabled {
+                    textarea_rect.x.saturating_add(1)
+                } else {
+                    textarea_rect.x
+                };
+                let placeholder_width = if self.draft.input_enabled {
+                    textarea_rect.width.saturating_sub(1)
+                } else {
+                    textarea_rect.width
+                };
+                if placeholder_width == 0 {
+                    return;
+                }
+
                 let placeholder = Span::from(text).dim();
-                Line::from(vec![placeholder])
-                    .render_ref(textarea_rect.inner(Margin::new(0, 0)), buf);
+                Line::from(vec![placeholder]).render_ref(
+                    Rect::new(
+                        placeholder_x,
+                        textarea_rect.y,
+                        placeholder_width,
+                        textarea_rect.height,
+                    ),
+                    buf,
+                );
             }
         }
     }
-- 
