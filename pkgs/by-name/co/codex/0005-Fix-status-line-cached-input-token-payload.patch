From 1b1aa94753f668dee412d7f928600bc443a5fbba Mon Sep 17 00:00:00 2001
From: FlameFlag <git@ps1.sh>
Date: Sat, 2 May 2026 11:46:14 +0300
Subject: [PATCH] Fix status-line cached input token payload

---
 codex-rs/tui/src/chatwidget/status_surfaces.rs | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/codex-rs/tui/src/chatwidget/status_surfaces.rs b/codex-rs/tui/src/chatwidget/status_surfaces.rs
index 1bc8baf05d..954cfae9d2 100644
--- a/codex-rs/tui/src/chatwidget/status_surfaces.rs
+++ b/codex-rs/tui/src/chatwidget/status_surfaces.rs
@@ -901,6 +901,7 @@ struct StatusLineCommandModel {
 struct StatusLineCommandContextUsage {
     input_tokens: u64,
     output_tokens: u64,
+    cached_input_tokens: u64,
     cache_creation_input_tokens: u64,
     cache_read_input_tokens: u64,
 }
@@ -986,8 +987,9 @@ fn build_status_line_command_payload(chat: &ChatWidget) -> String {
             current_usage: StatusLineCommandContextUsage {
                 input_tokens: usage.input_tokens.max(0) as u64,
                 output_tokens: usage.output_tokens.max(0) as u64,
+                cached_input_tokens: usage.cached_input_tokens.max(0) as u64,
                 cache_creation_input_tokens: 0,
-                cache_read_input_tokens: usage.cached_input_tokens.max(0) as u64,
+                cache_read_input_tokens: 0,
             },
         },
         rate_limits: StatusLineCommandRateLimits {
@@ -1151,6 +1153,10 @@ mod tests {
         );
         assert_eq!(
             value["context_window"]["current_usage"]["cache_read_input_tokens"],
+            0
+        );
+        assert_eq!(
+            value["context_window"]["current_usage"]["cached_input_tokens"],
             25
         );
         assert_eq!(value["rate_limits"]["five_hour"]["used_percentage"], 16.0);
-- 
