diff --git a/codex-rs/tui/src/bottom_pane/chat_composer.rs b/codex-rs/tui/src/bottom_pane/chat_composer.rs
index e752620..7058c83 100644
--- a/codex-rs/tui/src/bottom_pane/chat_composer.rs
+++ b/codex-rs/tui/src/bottom_pane/chat_composer.rs
@@ -4625,9 +4625,22 @@ impl ChatComposer {
                     .to_string()
             };
             if !textarea_rect.is_empty() {
+                let placeholder_x = if self.input_enabled {
+                    textarea_rect.x.saturating_add(1)
+                } else {
+                    textarea_rect.x
+                };
+                let placeholder_width = if self.input_enabled {
+                    textarea_rect.width.saturating_sub(1)
+                } else {
+                    textarea_rect.width
+                };
+                if placeholder_width == 0 {
+                    return;
+                }
                 if is_zellij {
                     buf.set_string(
-                        textarea_rect.x,
+                        placeholder_x,
                         textarea_rect.y,
                         text,
                         textarea_style.fg(ratatui::style::Color::White).italic(),
@@ -4635,7 +4648,15 @@ impl ChatComposer {
                 } else {
                     let placeholder = Span::from(text).dim();
                     let line = Line::from(vec![placeholder]);
-                    line.render_ref(textarea_rect.inner(Margin::new(0, 0)), buf);
+                    line.render_ref(
+                        Rect::new(
+                            placeholder_x,
+                            textarea_rect.y,
+                            placeholder_width,
+                            textarea_rect.height,
+                        ),
+                        buf,
+                    );
                 }
             }
         }
@@ -5412,6 +5433,53 @@ mod tests {
         snapshot_zellij_composer_state("zellij_empty_composer", |_composer| {});
     }
 
+    #[test]
+    fn empty_placeholder_starts_after_cursor_cell() {
+        let (tx, _rx) = unbounded_channel::<AppEvent>();
+        let sender = AppEventSender::new(tx);
+        let composer = ChatComposer::new(
+            /*has_input_focus*/ true,
+            sender,
+            /*enhanced_keys_supported*/ true,
+            "Ask Codex to do anything".to_string(),
+            /*disable_paste_burst*/ false,
+        );
+        let area = Rect::new(0, 0, 40, 5);
+        let mut buf = Buffer::empty(area);
+
+        composer.render(area, &mut buf);
+
+        let (cursor_x, cursor_y) = composer
+            .cursor_pos(area)
+            .expect("empty composer should expose a cursor position");
+        assert_eq!(buf[(cursor_x, cursor_y)].symbol(), " ");
+        assert_eq!(buf[(cursor_x.saturating_add(1), cursor_y)].symbol(), "A");
+    }
+
+    #[test]
+    fn zellij_empty_placeholder_starts_after_cursor_cell() {
+        let (tx, _rx) = unbounded_channel::<AppEvent>();
+        let sender = AppEventSender::new(tx);
+        let mut composer = ChatComposer::new(
+            /*has_input_focus*/ true,
+            sender,
+            /*enhanced_keys_supported*/ true,
+            "Ask Codex to do anything".to_string(),
+            /*disable_paste_burst*/ false,
+        );
+        composer.is_zellij = true;
+        let area = Rect::new(0, 0, 40, 5);
+        let mut buf = Buffer::empty(area);
+
+        composer.render(area, &mut buf);
+
+        let (cursor_x, cursor_y) = composer
+            .cursor_pos(area)
+            .expect("empty composer should expose a cursor position");
+        assert_eq!(buf[(cursor_x, cursor_y)].symbol(), " ");
+        assert_eq!(buf[(cursor_x.saturating_add(1), cursor_y)].symbol(), "A");
+    }
+
     #[test]
     fn esc_hint_stays_hidden_with_draft_content() {
         use crossterm::event::KeyCode;
