+#[derive(Serialize)]
+struct StatusLineCommandWorkspace {
+    current_dir: Option<String>,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandModel {
+    display_name: Option<String>,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandContextUsage {
+    input_tokens: u64,
+    output_tokens: u64,
+    cached_input_tokens: u64,
+    cache_creation_input_tokens: u64,
+    cache_read_input_tokens: u64,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandContextWindow {
+    used_percentage: Option<f64>,
+    context_window_size: Option<u64>,
+    current_usage: StatusLineCommandContextUsage,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandRateLimitWindow {
+    used_percentage: Option<f64>,
+    resets_at: Option<i64>,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandRateLimits {
+    five_hour: StatusLineCommandRateLimitWindow,
+    seven_day: StatusLineCommandRateLimitWindow,
+}
+
+#[derive(Serialize)]
+struct StatusLineCommandPayload {
+    workspace: StatusLineCommandWorkspace,
+    cwd: Option<String>,
+    session_id: Option<String>,
+    model: StatusLineCommandModel,
+    context_window: StatusLineCommandContextWindow,
+    rate_limits: StatusLineCommandRateLimits,
+}
+
+fn build_status_line_command_payload(chat: &ChatWidget) -> String {
+    let cwd = chat
+        .current_cwd
+        .as_ref()
+        .and_then(|cwd| cwd.to_str().map(str::to_owned))
+        .or_else(|| chat.config.cwd.to_str().map(str::to_owned));
+    let usage = chat.status_line_total_usage();
+    let context_window_size = chat.status_line_context_window_size();
+    let limit_snapshot = chat.rate_limit_snapshots_by_limit_id.get("codex");
+
+    let payload = StatusLineCommandPayload {
+        workspace: StatusLineCommandWorkspace {
+            current_dir: cwd.clone(),
+        },
+        cwd,
+        session_id: chat.thread_id.map(|id| id.to_string()),
+        model: StatusLineCommandModel {
+            display_name: Some(chat.model_display_name().to_string()),
+        },
+        context_window: StatusLineCommandContextWindow {
+            used_percentage: chat
+                .status_line_context_used_percent()
+                .map(|used| used as f64),
+            context_window_size: context_window_size.and_then(|size| u64::try_from(size).ok()),
+            current_usage: StatusLineCommandContextUsage {
+                input_tokens: usage.input_tokens.max(0) as u64,
+                output_tokens: usage.output_tokens.max(0) as u64,
+                cached_input_tokens: usage.cached_input_tokens.max(0) as u64,
+                cache_creation_input_tokens: 0,
+                cache_read_input_tokens: 0,
+            },
+        },
+        rate_limits: StatusLineCommandRateLimits {
+            five_hour: StatusLineCommandRateLimitWindow {
+                used_percentage: limit_snapshot
+                    .and_then(|snapshot| snapshot.primary.as_ref())
+                    .map(|window| window.used_percent),
+                resets_at: None,
+            },
+            seven_day: StatusLineCommandRateLimitWindow {
+                used_percentage: limit_snapshot
+                    .and_then(|snapshot| snapshot.secondary.as_ref())
+                    .map(|window| window.used_percent),
+                resets_at: None,
+            },
+        },
+    };
+
+    serde_json::to_string(&payload).unwrap_or_else(|_| "{}".to_string())
+}
+
+async fn run_status_line_command(
+    command: Vec<String>,
+    cwd: PathBuf,
+    payload: String,
+) -> Option<String> {
+    let mut child = Command::new(command.first()?);
+    child
+        .args(&command[1..])
+        .current_dir(cwd)
+        .stdin(Stdio::piped())
+        .stdout(Stdio::piped())
+        .stderr(Stdio::null());
+
+    let mut child = child.spawn().ok()?;
+    let mut stdout = child.stdout.take()?;
+    let stdout_task = tokio::spawn(async move {
+        let mut bytes = Vec::new();
+        let _ = stdout.read_to_end(&mut bytes).await;
+        bytes
+    });
+
+    if let Some(mut stdin) = child.stdin.take() {
+        if stdin.write_all(payload.as_bytes()).await.is_err() {
+            let _ = child.start_kill();
+            let _ = child.wait().await;
+            return None;
+        }
+    }
+
+    let status = match tokio::time::timeout(STATUS_LINE_COMMAND_TIMEOUT, child.wait()).await {
+        Ok(Ok(status)) => status,
+        Ok(Err(_)) => return None,
+        Err(_) => {
+            let _ = child.start_kill();
+            let _ = child.wait().await;
+            return None;
+        }
+    };
+
+    let stdout = stdout_task.await.ok()?;
+    if !status.success() {
+        return None;
+    }
+
+    let output = String::from_utf8_lossy(&stdout);
+    let output = output.trim_end_matches(['\r', '\n']);
+    (!output.trim().is_empty()).then(|| output.to_string())
+}
