+pub(super) fn status_line_diff_stats_from_unified_diff(diff: &str) -> StatusLineDiffStats {
+    let mut stats = StatusLineDiffStats::default();
+    for line in diff.lines() {
+        if line.starts_with("+++") || line.starts_with("---") {
+            continue;
+        }
+        if line.starts_with('+') {
+            stats.added = stats.added.saturating_add(1);
+        } else if line.starts_with('-') {
+            stats.removed = stats.removed.saturating_add(1);
+        }
+    }
+    stats
+}
