+++ b/codex-rs/config/src/types.rs
@@ -567,6 +567,14 @@ pub struct Tui {
     #[serde(default)]
     pub status_line: Option<Vec<String>>,
 
+    /// External command used to render the status line.
+    ///
+    /// When set, Codex runs this argv-style command in the active working directory, writes a
+    /// JSON snapshot of runtime status information to stdin, and renders stdout in the footer
+    /// status line. This overrides `status_line` item rendering while configured.
+    #[serde(default)]
+    pub status_line_command: Option<Vec<String>>,
+
     /// Ordered list of terminal title item identifiers.
     ///
     /// When set, the TUI renders the selected items into the terminal window/tab title.
