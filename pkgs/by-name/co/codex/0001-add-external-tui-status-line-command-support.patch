+    fn refresh_status_line_from_command(&mut self, command: Vec<String>) {
+        self.bottom_pane.set_status_line_enabled(true);
+        self.set_status_line_hyperlink(/*url*/ None);
+
+        let payload = build_status_line_command_payload(self);
+        self.status_line_command_desired_payload = Some(payload.clone());
+
+        if !self.status_line_command_pending
+            && self.status_line_command_running_payload.as_deref() != Some(payload.as_str())
+        {
+            self.status_line_command_running_payload = Some(payload.clone());
+            self.status_line_command_pending = true;
+
+            let cwd = self.status_line_cwd().to_path_buf();
+            let tx = self.app_event_tx.clone();
+            tokio::spawn(async move {
+                let output = run_status_line_command(command, cwd, payload).await;
+                tx.send(AppEvent::StatusLineCommandUpdated { output });
+            });
+        }
+
+        let line = self
+            .status_line_command_output
+            .as_deref()
+            .and_then(|output| ansi_escape(output).lines.into_iter().next());
+        self.set_status_line(line);
+    }
